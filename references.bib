}

@ARTICLE{Tan2025123,
	author = {Tan, Andong and Zhou, Fengtao and Chen, Hao},
	title = {Explain via Any Concept: Concept Bottleneck Model with Open Vocabulary Concepts},
	year = {2025},
	journal = {Lecture Notes in Computer Science},
