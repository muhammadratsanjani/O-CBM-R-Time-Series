@CONFERENCE{Sheth2023,
	author = {Sheth, Ivaxi and Kahou, Samira Ebrahimi},
	title = {Auxiliary Losses for Learning Generalizable Concept-based Models},
	year = {2023},
	journal = {Advances in Neural Information Processing Systems},
	volume = {36},
	pages = {},
	url = {https://www.scopus.com/pages/publications/85191188538?origin=resultslist},
	abstract = {The increasing use of neural networks in various applications has lead to increasing apprehensions, underscoring the necessity to understand their operations beyond mere final predictions. As a solution to enhance model transparency, Concept Bottleneck Models (CBMs) have gained popularity since their introduction. CBMs essentially limit the latent space of a model to human-understandable high-level concepts. While beneficial, CBMs have been reported to often learn irrelevant concept representations that consecutively damage model performance. To overcome the performance trade-off, we propose cooperative-Concept Bottleneck Model (coop-CBM). The concept representation of our model is particularly meaningful when fine-grained concept labels are absent. Furthermore, we introduce the concept orthogonal loss (COL) to encourage the separation between the concept representations and to reduce the intra-concept distance. This paper presents extensive experiments on real-world datasets for image classification tasks, namely CUB, AwA2, CelebA and TIL. We also study the performance of coop-CBM models under various distributional shift settings. We show that our proposed method achieves higher accuracy in all distributional shift settings even compared to the black-box models with the highest concept accuracy. Â© 2023 Neural information processing systems foundation. All rights reserved.},
	keywords = {Classification (of information); Bottleneck models; Concept-based; Damage modelling; Fine grained; Learn+; Model transparency; Modeling performance; Neural-networks; Performance tradeoff; Real-world datasets; Economic and social effects},
	type = {Conference paper},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 14}
}

@ARTICLE{Zabounidis2026,
	author = {Zabounidis, Renos and Oguntola, Ini and Zhao, Konghao and Campbell, Joseph and Kim, Woojun and Stepputtis, Simon and Sycara, Katia},
	title = {Disentangled Concept-Residual Models: Bridging the Inter pretabilityâ€“Performance Gap for Incomplete Concept Sets},
	year = {2026},
	journal = {Transactions on Machine Learning Research},
	volume = {2026-January},
	pages = {},
	url = {https://www.scopus.com/pages/publications/105029173701?origin=resultslist},
	abstract = {Deploying AI in high-stakes settings requires models that are not only accurate but also interpretable and amenable to human oversight. Concept Bottleneck Models (CBMs) support these goals by structuring predictions around human-understandable concepts, enabling interpretability via steerability and post-hoc human oversight. However, CBMs rely on a â€˜completeâ€™ concept set, requiring practitioners to define and label enough concepts to match the predictive power of black-box models. To relax this requirement, prior work introduced residual connections that bypass the concept layer and recover information missing from an incomplete concept set. While effective in bridging the performance gap, these residuals can redundantly encode concept information, a phenomenon we term concept-residual overlap. In this work, we investigate the effects of concept-residual overlap and evaluate strategies to mitigate it. We (1) define metrics to quantify the extent of concept-residual overlap in CRMs; (2) introduce complementary metrics to evaluate how this overlap impacts interpretability by reducing steerability to concept interventions; and (3) present Disentangled Concept-Residual Models (D-CRMs), a general class of CRMs designed to mitigate this issue. Within this class, we propose a novel disentanglement approach based on minimizing mutual information (MI). Using CelebA, CIFAR100, AA2, CUB, and OAI, we show that standard CRMs exhibit significant concept-residual overlap, and that reducing this overlap with MI-based D-CRMs restores the key properties of CBMs that make them interpretable, namely functional reliance on concepts and robust intervention behavior, without sacrificing predictive performance. Â© 2026, Transactions on Machine Learning Research. All rights reserved.},
	type = {Article},
	publication_stage = {Final},
	source = {Scopus},
	note = {Cited by: 0}
}

@CONFERENCE{Lee2026,
	author = {Lee, Yunyoung and Lee, Eungjoo},
	title = {Mitigating Domain Shift in Concept Bottleneck Models for Diabetic Retinopathy Grading via Learnable Concept Projection},
	year = {2026},
	journal = {Progress in Biomedical Optics and Imaging - Proceedings of SPIE},
	volume = {13928},
	pages = {},
	doi = {10.1117/12.3088213},
	url = {https://www.scopus.com/pages/publications/105039259217?origin=resultslist},
	abstract = {Concept bottleneck models (CBMs) offer interpretable diabetic retinopathy (DR) grading by routing predictions through clinically meaningful lesion concepts, yet they assume that training and deployment data share the same distribution. In practice, fundus images vary substantially across hospital sites due to differences in camera hardware, field of view, and patient demographics, causing concept predictors to misfire on out-of-distribution inputs. To address this limitation, we propose DICAN, a few-shot domain incremental learning framework that freezes all diagnostic components (backbone, prototype bank, and classification head) and trains only a low-rank residual projector (262K parameters). This projector realigns backbone features with frozen concept prototypes when a new hospital domain arrives with as few as 10 labeled images per grade. A multi-cluster prototype bank with best-match-then-aggregate scoring compresses sub-cluster similarities into three fixed statistics per concept, decoupling prototype granularity from classifier complexity and stabilizing few-shot adaptation. In this study, we evaluate DICAN across four sequential sessions using five multi-national DR datasets (DDR, FGADR, APTOS, Messidor-2, DRAC 2022). The proposed method achieves 54.37% average accuracy and 0.48 quadratic weighted kappa after all sessions, outperforming the strongest baseline by 10 percentage points in accuracy while halving forgetting. The concept bottleneck remains fully inspectable and correctable across all sessions, allowing clinicians to override lesion-concept scores and observe deterministic changes in the diagnostic output. Â© 2026 SPIE. All rights reserved.},
	author_keywords = {Concept Bottleneck Model; Diabetic Retinopathy; Few-Shot Domain Incremental Learning},
	keywords = {Classification (of information); Diagnosis; Hospitals; Medical applications; Medical imaging; Bottleneck models; Concept bottleneck model; Data share; Diabetic retinopathy; Diabetic retinopathy grading; Few-shot domain incremental learning; Field of views; Fundus image; Incremental learning; Routings; Grading},
